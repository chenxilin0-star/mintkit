# ============================================================
# MintKit Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# Google OAuth (NextAuth.js)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth.js
# For production, set to your domain: https://mintkit.vercel.app
NEXTAUTH_URL=https://mintkit.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Base URL (for metadata and PayPal callbacks)
NEXT_PUBLIC_BASE_URL=https://mintkit.vercel.app

# ============================================================
# Cloudflare D1 (Database)
# Set up a D1 database at: https://dash.cloudflare.com/
# Then run: wrangler d1 create mintkit
# ============================================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_API_TOKEN=

# ============================================================
# PayPal Subscription Integration
# Create app at: https://developer.paypal.com/
# ============================================================
# 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# Webhook verification secret (from PayPal Developer Dashboard)
PAYPAL_WEBHOOK_ID=

# PayPal Plan IDs (create these in PayPal Dashboard > Subscriptions > Plans)
# Basic Plan: $9.9/month
PAYPAL_BASIC_PLAN_ID=
# Premium Plan: $19.9/month
PAYPAL_PREMIUM_PLAN_ID=

# Internal API secret for webhooks
WEBHOOK_API_SECRET=***

# ============================================================
# Paddle Client Token (for Paddle.js SDK)
# Get from: https://dashboard.paddle.com/authentication
# ============================================================
PADDLE_CLIENT_TOKEN=
